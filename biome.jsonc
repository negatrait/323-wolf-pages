{
  // Remember to keep schema version === Biome version
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noAssignInExpressions": "error" },
      "style": { "noNonNullAssertion": "off" },
      "correctness": { "noUnusedImports": "warn" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "files": {
    "includes": [
      "src/**/*.tsx",
      "src/**/*.ts",
      "functions/**/*.ts",
      "vite-content-plugin.ts",
      "index.html",
      "vite.config.ts"
    ]
  }
}
